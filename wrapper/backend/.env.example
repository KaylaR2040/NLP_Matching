# Copy to .env for local development.
# .env is gitignored — never commit real credentials.
#
# For Render deployment, set these as Environment Variables in the Render dashboard.
# For Vercel frontend, set WRAPPER_API_BASE_URL in Vercel project settings.

# =============================================================================
# AUTH (REQUIRED — all four values must be set in production)
# =============================================================================
# Generate password hashes with:
#   python wrapper/backend/scripts/generate_password_hash.py --password "yourpassword"
WRAPPER_USER_USERNAME=replace_user_username
WRAPPER_USER_PASSWORD_HASH=pbkdf2_sha256$310000$replace_salt$replace_hash
WRAPPER_DEV_USERNAME=replace_dev_username
WRAPPER_DEV_PASSWORD_HASH=pbkdf2_sha256$310000$replace_salt$replace_hash

# Token signing secret — REQUIRED in production so tokens survive container restarts.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WRAPPER_TOKEN_SECRET=replace_with_random_64char_hex

# Token TTL in seconds (default 3600 = 1 hour).
WRAPPER_TOKEN_TTL_SECONDS=3600

# Max concurrent sessions per user.
WRAPPER_MAX_SESSIONS_PER_USER=5

# =============================================================================
# DATABASE (REQUIRED for postgres storage mode)
# =============================================================================
# Neon connection string. Copy from: Neon console → project → Connection Details.
# Format: postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=

# Storage mode: "postgres" uses Neon; "file" uses local JSON (local dev only).
WRAPPER_MENTOR_STORAGE_MODE=file
# Alias — main.py reads either DATABASE_URL or WRAPPER_MENTOR_DATABASE_URL.
WRAPPER_MENTOR_DATABASE_URL=

# =============================================================================
# CORS (REQUIRED in production — add all Flutter app origins)
# =============================================================================
# Comma-separated list. Default "*" (all) when unset — fine for local dev only.
# In production (Render backend), set to all deployed frontend URLs:
WRAPPER_ALLOWED_ORIGINS=https://mentorform.vercel.app,https://menteeform.vercel.app,https://matching-web-ten.vercel.app

# =============================================================================
# NLP PROJECT (REQUIRED in production)
# =============================================================================
# Path to the nlp_project directory. On Render (Docker), baked into the image at /app/nlp_project.
# On local dev, auto-discovered relative to repo root.
WRAPPER_NLP_PROJECT_DIR=nlp_project

# Timeout for /run_match. On Render, set to 270 (no 60s Vercel limit).
# On Vercel (if used for non-matching routes only), keep at 50.
WRAPPER_MATCH_TIMEOUT_SECONDS=50

# =============================================================================
# HTTPS ENFORCEMENT
# =============================================================================
# Set true in production (Render enforces HTTPS at the load balancer level).
WRAPPER_REQUIRE_HTTPS=true

# =============================================================================
# TIMEOUTS & RATE LIMITING
# =============================================================================
# Timeout for dev-file update scripts (pull_orgs, pull_concentrations).
WRAPPER_SCRIPT_TIMEOUT_SECONDS=45

# Login rate limiting.
WRAPPER_LOGIN_WINDOW_SECONDS=300
WRAPPER_LOGIN_MAX_ATTEMPTS_PER_IP=20
WRAPPER_LOGIN_MAX_ATTEMPTS_PER_USER=10
WRAPPER_LOGIN_LOCKOUT_SECONDS=600

# =============================================================================
# FILE PATHS (local dev overrides — defaults work for most setups)
# =============================================================================
WRAPPER_DATA_DIR=data
WRAPPER_BACKEND_ENV_PATH=.env
WRAPPER_DEV_RUNTIME_EDIT_DIR=/tmp/nlp_matching_runtime/dev_files
# On Render/Vercel, defaults to /tmp automatically. Override only if needed.
WRAPPER_DEV_BACKUP_DIR=

# Majors file path (defaults to grad_programs.txt).
MAJORS_PATH=data/majors.txt

# File-mode mentor storage (local dev fallback only — not used in postgres mode).
WRAPPER_MENTOR_STORE_PATH=data/mentors/mentors_store.json
WRAPPER_MENTOR_BACKUP_DIR=data/mentors/backups
WRAPPER_MATCHING_STATE_PATH=data/matching_state.json
WRAPPER_MENTOR_SOURCE_CSV_PATH=data/mentor_real.csv

# =============================================================================
# LINKEDIN ENRICHMENT (optional)
# =============================================================================
# Provider: auto | proxycurl | http | duckduckgo | mock
# auto = proxycurl if API key present, else http if configured, else duckduckgo.
WRAPPER_LINKEDIN_ENRICHMENT_ENABLED=true
WRAPPER_LINKEDIN_ENRICHMENT_PROVIDER=auto
WRAPPER_LINKEDIN_ENRICHMENT_HARD_DISABLE=false
WRAPPER_LINKEDIN_ENRICH_MIN_INTERVAL_SECONDS=0
WRAPPER_LINKEDIN_ENRICHMENT_TIMEOUT_SECONDS=20

# Proxycurl provider (optional paid service).
WRAPPER_LINKEDIN_PROXYCURL_API_KEY=
WRAPPER_LINKEDIN_PROXYCURL_ENDPOINT=https://nubela.co/proxycurl/api/v2/linkedin

# Generic HTTP provider (optional).
WRAPPER_LINKEDIN_PROVIDER_BASE_URL=
WRAPPER_LINKEDIN_PROVIDER_API_KEY=
WRAPPER_LINKEDIN_PROVIDER_API_KEY_HEADER=Authorization
WRAPPER_LINKEDIN_PROVIDER_API_KEY_PREFIX=Bearer
WRAPPER_LINKEDIN_PROVIDER_URL_PARAM=linkedin_url

# Search provider (DuckDuckGo fallback).
WRAPPER_LINKEDIN_SEARCH_ENDPOINT=https://duckduckgo.com/html/

# Public avatar/photo fallback.
WRAPPER_LINKEDIN_PUBLIC_PHOTO_ENDPOINT_TEMPLATE=https://unavatar.io/linkedin/{slug}?fallback=false
WRAPPER_LINKEDIN_PUBLIC_PHOTO_TIMEOUT_SECONDS=8

# =============================================================================
# GITHUB SYNC (optional — for persisting editable file edits across deployments)
# =============================================================================
# When enabled, saves to orgs/concentrations files are committed back to GitHub.
# Useful if you want edits from the admin UI to persist across Render redeploys.
# Not needed when config lists are stored in Neon (postgres mode).
WRAPPER_GITHUB_SYNC_ENABLED=false
WRAPPER_GITHUB_SYNC_TOKEN=
WRAPPER_GITHUB_SYNC_REPO=
WRAPPER_GITHUB_SYNC_BRANCH=main
WRAPPER_GITHUB_SYNC_TIMEOUT_SECONDS=20

# =============================================================================
# CONCENTRATIONS PULL SCRIPT
# =============================================================================
WRAPPER_CONCENTRATIONS_HTTP_TIMEOUT_SECONDS=8
WRAPPER_CONCENTRATIONS_HTTP_MAX_ATTEMPTS=2
WRAPPER_CONCENTRATIONS_HTTP_BACKOFF_SECONDS=1.0
