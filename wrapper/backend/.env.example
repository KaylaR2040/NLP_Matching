# Copy to .env for local-only configuration.
# .env is gitignored.

# Required auth configuration.
# Password values must be PBKDF2 hashes in format:
# pbkdf2_sha256$<iterations>$<base64url_salt>$<base64url_hash>
# Generate with:
# python wrapper/backend/scripts/generate_password_hash.py --password "<your-password>"
WRAPPER_USER_USERNAME=replace_user_username
WRAPPER_USER_PASSWORD_HASH=pbkdf2_sha256$310000$replace_salt$replace_hash
WRAPPER_DEV_USERNAME=replace_dev_username
WRAPPER_DEV_PASSWORD_HASH=pbkdf2_sha256$310000$replace_salt$replace_hash

# Optional token TTL in seconds (default 3600 = 1 hour).
# Use short access token TTL for better security.
WRAPPER_TOKEN_TTL_SECONDS=3600

# Optional max concurrent sessions per role-user.
WRAPPER_MAX_SESSIONS_PER_USER=5

# Require HTTPS for non-local traffic (set true in production).
WRAPPER_REQUIRE_HTTPS=true

# Login rate limiting settings.
WRAPPER_LOGIN_WINDOW_SECONDS=300
WRAPPER_LOGIN_MAX_ATTEMPTS_PER_IP=20
WRAPPER_LOGIN_MAX_ATTEMPTS_PER_USER=10
WRAPPER_LOGIN_LOCKOUT_SECONDS=600

# Optional data/path overrides (recommended for deployment where root is wrapper/backend).
WRAPPER_DATA_DIR=data
WRAPPER_BACKEND_ENV_PATH=.env
WRAPPER_NLP_PROJECT_DIR=nlp_project
WRAPPER_DEV_RUNTIME_EDIT_DIR=/tmp/nlp_matching_runtime/dev_files

# Optional override for majors file path.
MAJORS_PATH=data/majors.txt

# Optional mentor management storage paths.
# Mentor application data storage.
# Use postgres on Vercel; file mode is intended only for local development.
WRAPPER_MENTOR_STORAGE_MODE=file
WRAPPER_MENTOR_DATABASE_URL=

# File-mode mentor storage paths (local/dev fallback only).
WRAPPER_MENTOR_STORE_PATH=data/mentors/mentors_store.json
WRAPPER_MENTOR_BACKUP_DIR=data/mentors/backups
WRAPPER_MATCHING_STATE_PATH=data/matching_state.json

# Optional canonical CSV path used only for local snapshots / LinkedIn fallback lookups.
# Mentor app data is not stored here in production.
WRAPPER_MENTOR_SOURCE_CSV_PATH=data/mentor_real.csv

# LinkedIn enrichment (backend only)
# Provider options: auto, proxycurl, http, duckduckgo, mock
# - auto: proxycurl if API key present, otherwise generic http if configured, otherwise duckduckgo.
# - set WRAPPER_LINKEDIN_ENRICHMENT_HARD_DISABLE=true to force-disable enrichment.
WRAPPER_LINKEDIN_ENRICHMENT_ENABLED=true
WRAPPER_LINKEDIN_ENRICHMENT_PROVIDER=auto
WRAPPER_LINKEDIN_ENRICHMENT_HARD_DISABLE=false
WRAPPER_LINKEDIN_ENRICH_MIN_INTERVAL_SECONDS=0
WRAPPER_LINKEDIN_ENRICHMENT_TIMEOUT_SECONDS=20

# Proxycurl provider (optional)
WRAPPER_LINKEDIN_PROXYCURL_API_KEY=
WRAPPER_LINKEDIN_PROXYCURL_ENDPOINT=https://nubela.co/proxycurl/api/v2/linkedin

# Generic HTTP provider (optional)
WRAPPER_LINKEDIN_PROVIDER_BASE_URL=
WRAPPER_LINKEDIN_PROVIDER_API_KEY=
WRAPPER_LINKEDIN_PROVIDER_API_KEY_HEADER=Authorization
WRAPPER_LINKEDIN_PROVIDER_API_KEY_PREFIX=Bearer 
WRAPPER_LINKEDIN_PROVIDER_URL_PARAM=linkedin_url

# Search provider (optional)
WRAPPER_LINKEDIN_SEARCH_ENDPOINT=https://duckduckgo.com/html/

# Public avatar/photo fallback (optional)
WRAPPER_LINKEDIN_PUBLIC_PHOTO_ENDPOINT_TEMPLATE=https://unavatar.io/linkedin/{slug}?fallback=false
WRAPPER_LINKEDIN_PUBLIC_PHOTO_TIMEOUT_SECONDS=8

# GitHub-backed persistence for repo-backed editable files.
# Enable this in production so edits to files under nlp_project/ or wrapper/backend/
# are committed back to GitHub instead of only living in ephemeral runtime storage.
WRAPPER_GITHUB_SYNC_ENABLED=false
WRAPPER_GITHUB_SYNC_TOKEN=
WRAPPER_GITHUB_SYNC_REPO=
WRAPPER_GITHUB_SYNC_BRANCH=main
WRAPPER_GITHUB_SYNC_TIMEOUT_SECONDS=20

# Concentrations pull script network controls
WRAPPER_CONCENTRATIONS_HTTP_TIMEOUT_SECONDS=8
WRAPPER_CONCENTRATIONS_HTTP_MAX_ATTEMPTS=2
WRAPPER_CONCENTRATIONS_HTTP_BACKOFF_SECONDS=1.0

# Add private API tokens/keys here if future scripts require them.
# Example:
# SOME_API_KEY=replace_me
