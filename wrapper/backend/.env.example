# Copy to .env for local-only configuration.
# .env is gitignored.

# Required auth configuration.
# Password values must be PBKDF2 hashes in format:
# pbkdf2_sha256$<iterations>$<base64url_salt>$<base64url_hash>
# Generate with:
# python wrapper/backend/scripts/generate_password_hash.py --password "<your-password>"
WRAPPER_USER_USERNAME=replace_user_username
WRAPPER_USER_PASSWORD_HASH=pbkdf2_sha256$310000$replace_salt$replace_hash
WRAPPER_DEV_USERNAME=replace_dev_username
WRAPPER_DEV_PASSWORD_HASH=pbkdf2_sha256$310000$replace_salt$replace_hash

# Optional token TTL in seconds (default 3600 = 1 hour).
# Use short access token TTL for better security.
WRAPPER_TOKEN_TTL_SECONDS=3600

# Optional max concurrent sessions per role-user.
WRAPPER_MAX_SESSIONS_PER_USER=5

# Require HTTPS for non-local traffic (set true in production).
WRAPPER_REQUIRE_HTTPS=true

# Login rate limiting settings.
WRAPPER_LOGIN_WINDOW_SECONDS=300
WRAPPER_LOGIN_MAX_ATTEMPTS_PER_IP=20
WRAPPER_LOGIN_MAX_ATTEMPTS_PER_USER=10
WRAPPER_LOGIN_LOCKOUT_SECONDS=600

# Optional override for majors file path.
MAJORS_PATH=wrapper/backend/data/majors.txt

# Optional mentor management storage paths.
# Keep these backend-owned and deployment-safe (not frontend paths).
WRAPPER_MENTOR_STORE_PATH=wrapper/backend/data/mentors/mentors_store.json
WRAPPER_MENTOR_BACKUP_DIR=wrapper/backend/data/mentors/backups
WRAPPER_MENTOR_SOURCE_CSV_PATH=nlp_project/data/mentor_real.csv

# Add private API tokens/keys here if future scripts require them.
# Example:
# SOME_API_KEY=replace_me
